# Application Configuration
# Copy file ini menjadi .env dan sesuaikan dengan environment Anda
# File .env tidak boleh di-commit ke Git karena berisi sensitive data

# Service Information
SERVICE_NAME=user-service
ENVIRONMENT=development

# Application Port
# Port dimana aplikasi Go akan listen
PORT=8080

# Database Configuration
# Format: postgres://username:password@host:port/database?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@localhost:5432/userdb?sslmode=disable

# JWT Secret for Authentication
# PENTING: Ganti dengan random string yang aman di production
# Generate dengan: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-in-production

# Kong Configuration
# URL ke Kong Admin API untuk management
KONG_ADMIN_URL=http://localhost:8001

# Logging Level
# Options: debug, info, warn, error
LOG_LEVEL=info

# Redis Configuration (jika menggunakan Redis untuk caching)
# REDIS_URL=redis://localhost:6379/0

# External API Keys (contoh)
# SENDGRID_API_KEY=your-sendgrid-key
# AWS_ACCESS_KEY_ID=your-aws-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
